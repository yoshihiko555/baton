{
  "model": {
    "name": "gemini-3.1-pro-preview"
  },
  "context": {
    "fileName": [
      "GEMINI.md",
      "AGENTS.md"
    ],
    "discoveryMaxDirs": 200,
    "fileFiltering": {
      "respectGitIgnore": true,
      "respectGeminiIgnore": true
    }
  },
  "tools": {
    "sandbox": false,
    "autoAccept": false
  },
  "experimental": {
    "skills": true,
    "enableAgents": true
  },
  "skills": {
    "disabled": []
  },
  "mcpServers": {
    "cocoindex-code": {
      "command": "uvx",
      "args": [
        "--prerelease=explicit",
        "--with",
        "cocoindex>=1.0.0a16",
        "cocoindex-code@latest"
      ]
    }
  }
}